# Supabase
# 使用 port 6543（transaction mode pooler）避免 session-mode 連線數上限（15）被 Vexa 與 meetbot 共同佔滿
DATABASE_URL="postgresql://postgres.[PROJ]:[PWD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"
SUPABASE_URL="https://[PROJ].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="..."
SUPABASE_STORAGE_BUCKET="meeting-materials"

# Dify
DIFY_API_BASE="https://api.dify.ai/v1"
DIFY_DATASET_API_KEY="dataset-..."
DIFY_WORKFLOW_API_KEY="app-..."
DIFY_SUMMARY_WORKFLOW_API_KEY="app-..."
DIFY_MEETING_SUMMARY_WORKFLOW_API_KEY="app-..."
DIFY_CHATFLOW_TIMEOUT_MS=45000

# Anthropic，唯一的應用場景：無關聯專案的會議
ANTHROPIC_API_KEY="sk-ant-..."

# Vexa（需與 docker run 的 ADMIN_API_TOKEN 相同）
VEXA_API_URL="http://localhost:8056"
VEXA_WS_URL="ws://localhost:8056"

# Server
APP_PORT=4000
APP_CORS_ORIGINS="http://localhost:3000"
# 前端基底 URL，用於組出邀請接受連結（寄到信裡的 /invitations/accept?token=...）
APP_BASE_URL="http://localhost:3000"

# 寄信（專案邀請信）— 全部 optional
# 未設定時：邀請仍會建立，接受連結會印在 backend log，邀請對話框也會顯示可複製的連結，
#           只是不會真的寄出 email。要真的寄信才需要填以下設定。
#
# 用 Gmail 寄信的步驟：
#   1. 用「你自己的」Gmail（不是別人的），先到帳號設定開啟「兩步驟驗證」。
#   2. 到 https://myaccount.google.com/apppasswords 產生 16 碼「應用程式密碼」。
#   3. SMTP_PASS 填那 16 碼（把空格全部拿掉，連成一串，不要加引號）。
#   4. SMTP_USER / MAIL_FROM 填你自己的 Gmail。寄件人會顯示成這個帳號；收件人不限。
#   5. 改完 .env 後要「重啟 backend」才會生效（dev 沒有 watch）。
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="your-own@gmail.com"
SMTP_PASS="your16charapppassword"
MAIL_FROM="your-own@gmail.com"
# 邀請連結有效天數
INVITATION_TTL_DAYS=7