generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["app"]
}

// ══════════════════════════════════════════════════
// app schema：應用核心業務邏輯
// ══════════════════════════════════════════════════

model Project {
  id              String    @id @default(uuid())
  name            String
  ownerVexaUserId Int       @map("owner_vexa_user_id")
  difyDatasetId   String    @map("dify_dataset_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  members          ProjectMember[]
  invitations      ProjectInvitation[]
  materials        Material[]
  editHistory      MaterialEditHistory[]
  activityLogs     ActivityLog[]
  meetingInstances MeetingInstance[]

  @@index([ownerVexaUserId])
  @@index([deletedAt])
  @@map("projects")
  @@schema("app")
}

model ProjectMember {
  id                  String   @id @default(uuid())
  projectId           String   @map("project_id")
  vexaUserId          Int      @map("vexa_user_id")
  canView             Boolean  @default(true) @map("can_view")
  canEdit             Boolean  @default(false) @map("can_edit")
  canMeeting          Boolean  @default(false) @map("can_meeting")
  invitedByVexaUserId Int      @map("invited_by_vexa_user_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, vexaUserId])
  @@index([vexaUserId])
  @@map("project_members")
  @@schema("app")
}

/// 待處理的專案邀請。可邀請尚未在系統建立帳號的人（以 email 為依據）。
/// 對方登入後，後端以「已驗證的 Google email」比對 PENDING 邀請，於其信箱列出供接受。
/// token 僅存 SHA-256 hash；接受時強制 email 比對，避免連結外洩被冒領。
model ProjectInvitation {
  id                   String           @id @default(uuid())
  projectId            String           @map("project_id")
  email                String // 一律正規化為小寫儲存
  tokenHash            String           @unique @map("token_hash") // token 的 SHA-256（不存明碼）
  canView              Boolean          @default(true) @map("can_view")
  canEdit              Boolean          @default(false) @map("can_edit")
  canMeeting           Boolean          @default(false) @map("can_meeting")
  status               InvitationStatus @default(PENDING)
  invitedByVexaUserId  Int              @map("invited_by_vexa_user_id")
  acceptedByVexaUserId Int?             @map("accepted_by_vexa_user_id")
  expiresAt            DateTime         @map("expires_at")
  acceptedAt           DateTime?        @map("accepted_at")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([email, status])
  @@index([projectId, status])
  @@map("project_invitations")
  @@schema("app")
}

model Material {
  id                   String         @id @default(uuid())
  projectId            String         @map("project_id")
  filename             String
  displayName          String         @map("display_name")
  sizeBytes            BigInt         @map("size_bytes")
  mimeType             String         @map("mime_type")
  sha256               String
  storagePath          String         @map("storage_path")
  difyDocumentId       String?        @map("dify_document_id")
  difyBatch            String?        @map("dify_batch")
  indexingStatus       IndexingStatus @default(PENDING) @map("indexing_status")
  indexingError        String?        @map("indexing_error")
  uploadedByVexaUserId Int            @map("uploaded_by_vexa_user_id")
  uploadedAt           DateTime       @default(now()) @map("uploaded_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  deletedAt            DateTime?      @map("deleted_at")

  project     Project               @relation(fields: [projectId], references: [id])
  editHistory MaterialEditHistory[]

  @@unique([projectId, sha256])
  @@index([projectId, uploadedAt(sort: Desc)])
  @@index([indexingStatus])
  @@map("materials")
  @@schema("app")
}

model MaterialEditHistory {
  id                    String     @id @default(uuid())
  projectId             String     @map("project_id")
  materialId            String     @map("material_id")
  action                EditAction
  filenameSnapshot      String     @map("filename_snapshot")
  performedByVexaUserId Int        @map("performed_by_vexa_user_id")
  performedAt           DateTime   @default(now()) @map("performed_at")

  project  Project  @relation(fields: [projectId], references: [id])
  material Material @relation(fields: [materialId], references: [id])

  @@index([projectId, performedAt(sort: Desc)])
  @@index([materialId])
  @@map("material_edit_history")
  @@schema("app")
}

/// 通用活動紀錄：素材增刪、成員增減、權限變更、會議建立、專案改名等。
/// 與 MaterialEditHistory 不同，本表不綁定特定 materialId，可記錄任意專案層級事件。
model ActivityLog {
  id              String         @id @default(uuid())
  projectId       String         @map("project_id")
  actorVexaUserId Int            @map("actor_vexa_user_id")
  action          ActivityAction
  targetLabel     String         @map("target_label") // 事件對象的快照字串（檔名 / 成員 email / 會議名稱）
  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt(sort: Desc)])
  @@map("activity_logs")
  @@schema("app")
}

model MeetingInstance {
  id                    String        @id @default(uuid())
  projectId             String?       @map("project_id")
  vexaMeetingId         Int?          @map("vexa_meeting_id")
  vexaNativeMeetingId   String?       @map("vexa_native_meeting_id")
  name                  String
  googleMeetUrl         String        @map("google_meet_url")
  status                MeetingStatus @default(PENDING)
  createdByVexaUserId   Int           @map("created_by_vexa_user_id")
  creatorApiTokenId     Int           @map("creator_api_token_id")
  startedAt             DateTime?     @map("started_at")
  endedAt               DateTime?     @map("ended_at")
  summary               String?
  actionItems           Json?         @map("action_items")
  keyTopics             Json?         @map("key_topics")
  decisions             Json?
  transcriptStoragePath String?       @map("transcript_storage_path")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  project Project? @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt(sort: Desc)])
  @@index([createdByVexaUserId, createdAt(sort: Desc)])
  @@index([vexaMeetingId])
  @@index([status])
  @@index([createdByVexaUserId, status])
  @@map("meeting_instances")
  @@schema("app")
}

// ── Enums ──────────────────────────────────────────

enum IndexingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED

  @@map("indexing_status")
  @@schema("app")
}

enum EditAction {
  UPLOAD
  DELETE

  @@map("edit_action")
  @@schema("app")
}

enum ActivityAction {
  MATERIAL_UPLOAD
  MATERIAL_DELETE
  MEMBER_INVITE
  MEMBER_ADD
  MEMBER_REMOVE
  MEMBER_PERMISSION_UPDATE
  MEETING_CREATE
  PROJECT_RENAME

  @@map("activity_action")
  @@schema("app")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
  EXPIRED

  @@map("invitation_status")
  @@schema("app")
}

enum MeetingStatus {
  PENDING
  ACTIVE
  ENDED
  FAILED

  @@map("meeting_status")
  @@schema("app")
}